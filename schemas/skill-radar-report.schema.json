{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radar.dailyingest.cn/schemas/skill-radar-report-v2.json",
  "title": "Personal Radar structured skill report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "channel",
    "reportDate",
    "summary",
    "conclusion",
    "stats",
    "items",
    "socialDecisions"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "status": { "enum": ["published", "no_update"] },
    "channel": { "const": "skill-radar" },
    "reportDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "summary": { "$ref": "#/$defs/localizedText" },
    "conclusion": { "$ref": "#/$defs/localizedText" },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewedCount",
        "selectedCount",
        "duplicateCount",
        "rejectedCount",
        "sourceCounts",
        "xDiscovery"
      ],
      "properties": {
        "reviewedCount": { "type": "integer", "minimum": 8 },
        "selectedCount": { "type": "integer", "minimum": 0, "maximum": 6 },
        "duplicateCount": { "type": "integer", "minimum": 0 },
        "rejectedCount": { "type": "integer", "minimum": 0 },
        "sourceCounts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "xDiscovery": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "searched",
            "candidateCount",
            "verifiedCount",
            "selectedCount",
            "rejectedCount",
            "deferredCount"
          ],
          "properties": {
            "searched": { "type": "boolean" },
            "candidateCount": { "type": "integer", "minimum": 0 },
            "verifiedCount": { "type": "integer", "minimum": 0 },
            "selectedCount": { "type": "integer", "minimum": 0 },
            "rejectedCount": { "type": "integer", "minimum": 0 },
            "deferredCount": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "items": {
      "type": "array",
      "maxItems": 6,
      "items": { "$ref": "#/$defs/item" }
    },
    "socialDecisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/socialDecision" }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zh", "en"],
      "properties": {
        "zh": { "$ref": "#/$defs/nonEmptyString" },
        "en": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "oneLiner",
        "whyNow",
        "bestFor",
        "action",
        "primaryCaution",
        "problem",
        "usability",
        "adaptation",
        "trust"
      ],
      "properties": {
        "oneLiner": { "$ref": "#/$defs/nonEmptyString" },
        "whyNow": { "$ref": "#/$defs/nonEmptyString" },
        "bestFor": { "$ref": "#/$defs/nonEmptyString" },
        "action": { "$ref": "#/$defs/nonEmptyString" },
        "primaryCaution": { "$ref": "#/$defs/nonEmptyString" },
        "problem": { "$ref": "#/$defs/nonEmptyString" },
        "usability": { "$ref": "#/$defs/nonEmptyString" },
        "adaptation": { "$ref": "#/$defs/nonEmptyString" },
        "trust": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valueClarity",
        "nativeUsabilityPortability",
        "implementationQuality",
        "maintenanceHealth",
        "communityValidation",
        "trustSafetyLicense",
        "differentiation"
      ],
      "properties": {
        "valueClarity": { "type": "integer", "minimum": 0, "maximum": 20 },
        "nativeUsabilityPortability": { "type": "integer", "minimum": 0, "maximum": 20 },
        "implementationQuality": { "type": "integer", "minimum": 0, "maximum": 15 },
        "maintenanceHealth": { "type": "integer", "minimum": 0, "maximum": 10 },
        "communityValidation": { "type": "integer", "minimum": 0, "maximum": 15 },
        "trustSafetyLicense": { "type": "integer", "minimum": 0, "maximum": 10 },
        "differentiation": { "type": "integer", "minimum": 0, "maximum": 10 }
      }
    },
    "evidenceState": {
      "enum": ["met", "not_met", "unknown", "not_applicable"]
    },
    "qualityEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactScope",
        "declaredPlatforms",
        "value",
        "usability",
        "implementation",
        "maintenance",
        "community",
        "security",
        "differentiation",
        "evidenceRefs"
      ],
      "properties": {
        "artifactScope": {
          "enum": [
            "individual_skill",
            "focused_skill_pack",
            "general_skill_collection",
            "official_catalog",
            "curated_list",
            "mixed_toolkit"
          ]
        },
        "declaredPlatforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "codex",
              "claude-code",
              "cursor",
              "cline",
              "roo-code",
              "hermes",
              "github-copilot",
              "gemini-cli",
              "generic-agent",
              "other"
            ]
          }
        },
        "value": {
          "type": "object",
          "additionalProperties": false,
          "required": ["specificTaskDefined", "targetUserDefined", "inputsOutputsDefined", "workflowImprovementDefined", "officialDemonstration", "independentOutcomeEvidence"],
          "properties": {
            "specificTaskDefined": { "$ref": "#/$defs/evidenceState" },
            "targetUserDefined": { "$ref": "#/$defs/evidenceState" },
            "inputsOutputsDefined": { "$ref": "#/$defs/evidenceState" },
            "workflowImprovementDefined": { "$ref": "#/$defs/evidenceState" },
            "officialDemonstration": { "$ref": "#/$defs/evidenceState" },
            "independentOutcomeEvidence": { "$ref": "#/$defs/evidenceState" }
          }
        },
        "usability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reusableContentPresent", "targetPlatformsDocumented", "nativeInstallInstructions", "nativeUsageExample", "dependenciesAndPermissionsDocumented", "validationMethodAvailable", "coreInstructionsPortable", "multiPlatformSupport", "adaptationGuideAvailable"],
          "properties": {
            "reusableContentPresent": { "$ref": "#/$defs/evidenceState" },
            "targetPlatformsDocumented": { "$ref": "#/$defs/evidenceState" },
            "nativeInstallInstructions": { "$ref": "#/$defs/evidenceState" },
            "nativeUsageExample": { "$ref": "#/$defs/evidenceState" },
            "dependenciesAndPermissionsDocumented": { "$ref": "#/$defs/evidenceState" },
            "validationMethodAvailable": { "$ref": "#/$defs/evidenceState" },
            "coreInstructionsPortable": { "$ref": "#/$defs/evidenceState" },
            "multiPlatformSupport": { "$ref": "#/$defs/evidenceState" },
            "adaptationGuideAvailable": { "$ref": "#/$defs/evidenceState" }
          }
        },
        "implementation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["documentedStructureMatches", "coreFilesSubstantive", "triggerOrScopeDefined", "executableStepsDefined", "constraintsAndFailureModesDefined", "testsOrReviewableExamples"],
          "properties": {
            "documentedStructureMatches": { "$ref": "#/$defs/evidenceState" },
            "coreFilesSubstantive": { "$ref": "#/$defs/evidenceState" },
            "triggerOrScopeDefined": { "$ref": "#/$defs/evidenceState" },
            "executableStepsDefined": { "$ref": "#/$defs/evidenceState" },
            "constraintsAndFailureModesDefined": { "$ref": "#/$defs/evidenceState" },
            "testsOrReviewableExamples": { "$ref": "#/$defs/evidenceState" }
          }
        },
        "maintenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repositoryAgeDays",
            "commitCount90d",
            "activeMonths12m",
            "releaseCount12m",
            "contributorCount12m",
            "independentIssueOrPrParticipants90d",
            "hasUnresolvedBlockingIssues",
            "archived",
            "maintenanceEnded"
          ],
          "properties": {
            "repositoryAgeDays": { "type": ["integer", "null"], "minimum": 0 },
            "commitCount90d": { "type": ["integer", "null"], "minimum": 0 },
            "activeMonths12m": { "type": ["integer", "null"], "minimum": 0, "maximum": 12 },
            "releaseCount12m": { "type": ["integer", "null"], "minimum": 0 },
            "contributorCount12m": { "type": ["integer", "null"], "minimum": 0 },
            "independentIssueOrPrParticipants90d": { "type": ["integer", "null"], "minimum": 0 },
            "hasUnresolvedBlockingIssues": { "type": ["boolean", "null"] },
            "archived": { "type": ["boolean", "null"] },
            "maintenanceEnded": { "type": ["boolean", "null"] }
          }
        },
        "community": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stars",
            "contributors",
            "independentParticipants90d",
            "independentAdoptions",
            "starsGrowth30d",
            "starsGrowth90d",
            "credibleOrganizationBacking",
            "verifiableUsageCase",
            "itemLevelAdoptionEvidence",
            "skillSpecificAttentionEvidence"
          ],
          "properties": {
            "stars": { "type": ["integer", "null"], "minimum": 0 },
            "contributors": { "type": ["integer", "null"], "minimum": 0 },
            "independentParticipants90d": { "type": ["integer", "null"], "minimum": 0 },
            "independentAdoptions": { "type": ["integer", "null"], "minimum": 0 },
            "starsGrowth30d": { "type": ["integer", "null"], "minimum": 0 },
            "starsGrowth90d": { "type": ["integer", "null"], "minimum": 0 },
            "credibleOrganizationBacking": { "$ref": "#/$defs/evidenceState" },
            "verifiableUsageCase": { "$ref": "#/$defs/evidenceState" },
            "itemLevelAdoptionEvidence": { "$ref": "#/$defs/evidenceState" },
            "skillSpecificAttentionEvidence": { "$ref": "#/$defs/evidenceState" }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": ["licensePresent", "permissionsDocumented", "externalBehaviorDocumented", "dangerousActionsRequireConfirmation", "installationAuditable", "securityPolicyPresent", "applicableOpenSsfEvidence", "secretExposureRequested", "destructiveByDefault", "unreviewedRemoteExecution", "unnecessaryElevatedPermissions", "safetyReviewBypass", "knownMaliciousBehavior"],
          "properties": {
            "licensePresent": { "$ref": "#/$defs/evidenceState" },
            "permissionsDocumented": { "$ref": "#/$defs/evidenceState" },
            "externalBehaviorDocumented": { "$ref": "#/$defs/evidenceState" },
            "dangerousActionsRequireConfirmation": { "$ref": "#/$defs/evidenceState" },
            "installationAuditable": { "$ref": "#/$defs/evidenceState" },
            "securityPolicyPresent": { "$ref": "#/$defs/evidenceState" },
            "applicableOpenSsfEvidence": { "$ref": "#/$defs/evidenceState" },
            "secretExposureRequested": { "$ref": "#/$defs/evidenceState" },
            "destructiveByDefault": { "$ref": "#/$defs/evidenceState" },
            "unreviewedRemoteExecution": { "$ref": "#/$defs/evidenceState" },
            "unnecessaryElevatedPermissions": { "$ref": "#/$defs/evidenceState" },
            "safetyReviewBypass": { "$ref": "#/$defs/evidenceState" },
            "knownMaliciousBehavior": { "$ref": "#/$defs/evidenceState" }
          }
        },
        "differentiation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "comparisonSources",
            "newProblemCoverage",
            "newAgentFormatOrWorkflow",
            "fewerAdaptationSteps",
            "newValidationMechanism",
            "newSecurityOrCollaborationBoundary"
          ],
          "properties": {
            "comparisonSources": {
              "type": "array",
              "items": { "$ref": "#/$defs/httpsUrl" }
            },
            "newProblemCoverage": { "$ref": "#/$defs/evidenceState" },
            "newAgentFormatOrWorkflow": { "$ref": "#/$defs/evidenceState" },
            "fewerAdaptationSteps": { "$ref": "#/$defs/evidenceState" },
            "newValidationMechanism": { "$ref": "#/$defs/evidenceState" },
            "newSecurityOrCollaborationBoundary": { "$ref": "#/$defs/evidenceState" }
          }
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "source", "location", "observedAt"],
            "properties": {
              "field": { "$ref": "#/$defs/nonEmptyString" },
              "source": { "enum": ["github", "official-docs", "oss-insight", "openssf", "deps-dev", "radarai", "x", "manual-review"] },
              "location": { "$ref": "#/$defs/nonEmptyString" },
              "observedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seenWithin30Days",
        "previousDates",
        "materialChange",
        "changeEvidence"
      ],
      "properties": {
        "seenWithin30Days": { "type": "boolean" },
        "previousDates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        },
        "materialChange": { "type": "boolean" },
        "changeEvidence": { "type": ["string", "null"] }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimensions",
        "evidence",
        "baseScore",
        "preferenceAdjustment",
        "finalRankScore",
        "skillLike",
        "officialSourceVerified",
        "sourceCheckedAt",
        "license",
        "history"
      ],
      "properties": {
        "dimensions": { "$ref": "#/$defs/dimensions" },
        "evidence": { "$ref": "#/$defs/qualityEvidence" },
        "baseScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "preferenceAdjustment": { "type": "integer", "minimum": -5, "maximum": 5 },
        "finalRankScore": { "type": "integer", "minimum": 0, "maximum": 105 },
        "skillLike": { "const": true },
        "officialSourceVerified": { "const": true },
        "sourceCheckedAt": {
          "type": "string",
          "format": "date-time"
        },
        "license": { "type": ["string", "null"] },
        "history": { "$ref": "#/$defs/history" }
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url", "author", "publishedAt"],
      "properties": {
        "type": { "enum": ["github", "web", "x", "inbox"] },
        "url": { "$ref": "#/$defs/httpsUrl" },
        "author": { "type": ["string", "null"] },
        "publishedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rank",
        "title",
        "category",
        "sourceUrl",
        "canonicalUrl",
        "recommendation",
        "discovery",
        "display",
        "quality"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^src_[a-f0-9]{8}$"
        },
        "rank": { "type": "integer", "minimum": 1, "maximum": 6 },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "category": { "$ref": "#/$defs/nonEmptyString" },
        "sourceUrl": { "$ref": "#/$defs/httpsUrl" },
        "canonicalUrl": { "$ref": "#/$defs/httpsUrl" },
        "recommendation": { "enum": ["install", "adapt", "watch", "skip"] },
        "discovery": { "$ref": "#/$defs/discovery" },
        "display": {
          "type": "object",
          "additionalProperties": false,
          "required": ["zh", "en"],
          "properties": {
            "zh": { "$ref": "#/$defs/display" },
            "en": { "$ref": "#/$defs/display" }
          }
        },
        "quality": { "$ref": "#/$defs/quality" }
      }
    },
    "socialDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postUrl", "status", "officialUrl", "reason"],
      "properties": {
        "postUrl": { "$ref": "#/$defs/httpsUrl" },
        "status": { "enum": ["verified", "selected", "rejected", "deferred"] },
        "officialUrl": {
          "anyOf": [
            { "$ref": "#/$defs/httpsUrl" },
            { "type": "null" }
          ]
        },
        "reason": { "$ref": "#/$defs/nonEmptyString" }
      }
    }
  }
}
